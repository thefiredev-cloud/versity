{
  "name": "@thefiredev/versity",
  "version": "0.1.0",
  "description": "The Infinite Intern. Every white-collar entry-level role on demand. One subscription.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "db:migrate": "tsx src/utils/migrate.ts",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "ai-assistant",
    "virtual-intern",
    "legal-ai",
    "finance-ai",
    "recruiting-ai",
    "marketing-ai",
    "role-based-ai"
  ],
  "author": "The Fire Dev LLC <hello@thefiredev.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/thefiredev/versity.git"
  },
  "homepage": "https://thefiredev.com/versity",
  "bugs": {
    "url": "https://github.com/thefiredev/versity/issues"
  },
  "dependencies": {
    "fastify": "^4.28.0",
    "@fastify/cors": "^9.0.0",
    "@fastify/multipart": "^8.3.0",
    "zod": "^3.23.0",
    "drizzle-orm": "^0.30.0",
    "pg": "^8.11.0",
    "ioredis": "^5.3.0",
    "openai": "^4.47.0",
    "@pinecone-database/pinecone": "^3.0.0",
    "pino": "^9.1.0",
    "pino-pretty": "^11.0.0",
    "dotenv": "^16.4.0",
    "pdf-parse": "^1.1.1",
    "mammoth": "^1.7.0"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "tsx": "^4.11.0",
    "vitest": "^1.6.0",
    "@vitest/coverage-v8": "^1.6.0",
    "eslint": "^8.57.0",
    "@typescript-eslint/eslint-plugin": "^7.9.0",
    "@typescript-eslint/parser": "^7.9.0",
    "prettier": "^3.3.0",
    "drizzle-kit": "^0.21.0",
    "@types/node": "^20.13.0",
    "@types/pg": "^8.11.0",
    "@types/pdf-parse": "^1.1.4"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
